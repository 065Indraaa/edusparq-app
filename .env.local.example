# =======================================
# EduSparq — Contoh Environment Variables
# Salin file ini menjadi `.env.local` lalu isi nilainya.
# JANGAN commit file `.env.local` yang berisi rahasia.
# =======================================

# --- MongoDB Atlas ---
# Dapatkan dari: https://cloud.mongodb.com -> Connect -> Drivers
# PENTING (deploy): di Atlas, Network Access harus mengizinkan IP host.
# Untuk platform tanpa IP statis (Wasmer/serverless) izinkan 0.0.0.0/0.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/edusparq?retryWrites=true&w=majority

# --- NextAuth / Auth.js v5 ---
# Generate: openssl rand -base64 32
# Boleh pakai NEXTAUTH_SECRET atau AUTH_SECRET (keduanya didukung kode).
NEXTAUTH_SECRET=ganti-dengan-string-acak-32-karakter
# URL publik aplikasi saat di-deploy (mis. https://edusparq-namamu.wasmer.app)
NEXTAUTH_URL=http://localhost:3000
# trustHost sudah di-set true di kode; variabel ini opsional untuk self-host.
AUTH_TRUST_HOST=true

# --- Google OAuth (opsional) ---
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Untuk sinkronisasi Google Calendar, aktifkan "Google Calendar API" di Cloud Console.
# Authorized redirect URI HARUS: <NEXTAUTH_URL>/api/google/callback
# (opsional; kalau kosong, otomatis diturunkan dari NEXTAUTH_URL)
GOOGLE_REDIRECT_URI=

# --- Groq API (wajib untuk Tutor AI, Outline, Riset) ---
# Gratis di: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# --- Model AI tambahan (OPSIONAL — semua otomatis fallback ke Groq bila kosong) ---
# Kimi K2.6 (Moonshot): grading & generate soal lebih akurat. https://platform.moonshot.ai
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# Gemini Flash: ringkasan & rekomendasi (gratis tier). https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx

# --- Indonesia University Data API (opsional, untuk Personalisasi Kampus) ---
# Daftar gratis di: https://api.co.id  (limit 3000 hits/bulan).
# Tanpa key ini, pemilihan universitas otomatis jadi input manual biasa (tidak error).
API_CO_ID_KEY=your-api-co-id-key

# --- Cloudinary (opsional, untuk unggah materi) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Pusher (opsional, untuk kolaborasi realtime) ---
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=ap1
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
